# Environment variables template — copy to .env and fill in real values
# .env is git-ignored; never commit secrets.

# =============================================================================
# AI Assistant Settings
# =============================================================================
# OpenAI API key (required for AI-assisted features)
OPENAI_API_KEY=

# Model to use for test generation and analysis
AI_MODEL=gpt-4o-mini

# Maximum tokens for AI responses
AI_MAX_TOKENS=2048

# =============================================================================
# API Testing Settings
# =============================================================================
# Base URL for the API under test
API_BASE_URL=https://jsonplaceholder.typicode.com

# Default request timeout in seconds
API_TIMEOUT=30

# =============================================================================
# UI Testing Settings
# =============================================================================
# Base URL for the UI under test
UI_BASE_URL=https://example.com

# Browser to use: chromium | firefox | webkit
BROWSER=chromium

# Run browser in headless mode (true/false)
HEADLESS=true

# Browser viewport width
VIEWPORT_WIDTH=1280

# Browser viewport height
VIEWPORT_HEIGHT=720

# =============================================================================
# Reporting Settings
# =============================================================================
# Directory for test reports
REPORT_DIR=reports

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
